PORT=8787
CORS_ORIGIN=*
DATABASE_URL=
SQLITE_PATH=./data/leaderboard.sqlite
ALLOWED_PUBLIC_KEYS=
ADMIN_TOKEN=change-this-to-a-long-random-secret
# Session login for the admin panel (used by the embedded hub).
ADMIN_PASSWORD=change-this-to-a-strong-password
SESSION_SECRET=change-this-to-a-long-random-secret
SESSION_TTL_SECONDS=43200
# Hub single sign-on (short-lived HS256 JWT, aud "leaderboard").
LEADERBOARD_SSO_SECRET=change-this-to-a-long-random-secret
LEADERBOARD_SSO_AUDIENCE=leaderboard
# Origin allowed to embed the admin panel in an iframe.
HUB_ORIGIN=https://admin-panel-production-39e5.up.railway.app
MAX_USERNAME_LENGTH=127
MAX_EXTRA_LENGTH=100
